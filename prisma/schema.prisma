// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model GolfClient {
  id               Int       @id @default(autoincrement())
  ghlContactId     String?   @unique
  ghlLastSyncedAt  DateTime?
  ghlSyncStatus    String?
  ghlSyncError     String?   @db.Text
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  demoSessions DemoSession[]
}

model DemoSession {
  id                        Int       @id @default(autoincrement())
  clientId                  Int
  lockerToken               String    @unique
  lockerUrl                 String?
  demoDate                  DateTime  @default(now())
  salesRep                  String?
  journeyStage              String    @default("demo_completed")
  currentClub               String?
  clientGoal                String?
  notes                     String?   @db.Text
  ghlOpportunityId          String?
  ghlLockerReadyTagAddedAt  DateTime?
  ghlLastSyncedAt           DateTime?
  ghlSyncStatus             String?
  ghlSyncError              String?   @db.Text
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  client        GolfClient     @relation(fields: [clientId], references: [id])
  clubTests     DemoClubTest[]
  ghlSyncEvents GhlSyncEvent[]

  @@index([clientId])
  @@index([journeyStage])
  @@index([demoDate])
}

model DemoClubTest {
  id             Int      @id @default(autoincrement())
  demoSessionId  Int
  clubType       String?
  brand          String?
  model          String?
  shaft          String?
  loft           String?
  estimatedPrice Decimal? @db.Decimal(10, 2)
  notes          String?  @db.Text
  isRecommended  Boolean  @default(false)
  sortOrder      Int      @default(0)
  clubRole       String   @default("demo")
  pairIndex      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  demoSession DemoSession      @relation(fields: [demoSessionId], references: [id])
  metrics     ClubTestMetrics?

  @@index([demoSessionId])
}

model ClubTestMetrics {
  id            Int      @id @default(autoincrement())
  clubTestId    Int      @unique
  clubSpeed     Decimal? @db.Decimal(6, 2)
  ballSpeed     Decimal? @db.Decimal(6, 2)
  smashFactor   Decimal? @db.Decimal(5, 2)
  carryDistance Decimal? @db.Decimal(6, 2)
  totalDistance Decimal? @db.Decimal(6, 2)
  launchAngle   Decimal? @db.Decimal(5, 2)
  spinRate      Int?
  dispersion    Decimal? @db.Decimal(6, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clubTest DemoClubTest @relation(fields: [clubTestId], references: [id])
}

model GhlSyncEvent {
  id            Int      @id @default(autoincrement())
  demoSessionId Int
  ghlContactId  String?
  eventType     String
  status        String   @default("pending")
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  demoSession DemoSession @relation(fields: [demoSessionId], references: [id])

  @@index([demoSessionId])
  @@index([status])
  @@index([eventType])
}

// ── Staff Authentication ───────────────────────────────────────────────────────
// Used by internal sales reps / staff only.
// Golfer/customer auth is intentionally separate and not part of this system.
//
// Auth flow (passwordless OTP):
//   POST /api/staff-auth/request-code  — lookup staff by email or phone, create StaffOtp
//   POST /api/staff-auth/verify-code   — verify code, issue HMAC-signed session cookie
//   POST /api/staff-auth/logout        — clear session cookie
//
// Sessions are NOT stored in the database. They are self-verifying HMAC tokens
// stored as HTTP-only cookies. StaffOtp is single-use and expires in 10 minutes.

model StaffUser {
  id        Int       @id @default(autoincrement())
  // At least one of email or phone must be present (enforced at app level in V1)
  email     String?   @unique
  phone     String?   @unique
  name      String?
  role      String    @default("sales_rep")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  otps          StaffOtp[]
  importBatches ImportBatch[]
}

model StaffOtp {
  id          Int       @id @default(autoincrement())
  staffUserId Int
  // SHA-256 hash of the 6-digit numeric code — raw code is never stored
  codeHash    String
  expiresAt   DateTime
  // Set when the OTP is consumed — used to enforce single-use
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  staff StaffUser @relation(fields: [staffUserId], references: [id])

  @@index([staffUserId])
  @@index([expiresAt])
  @@index([usedAt])
}

// ── Import Staging Layer ───────────────────────────────────────────────────────
// Generic file import pipeline for CSV / XLSX uploads.
//
// Design intent:
//   unknown CSV/XLSX → ImportBatch + ImportRow staging → human review
//   → future: normalize into GolfClient / DemoSession / DemoClubTest
//
// ImportRow.rawData is intentionally unstructured Json — we do NOT know the
// exact TrackMan export schema yet.  Mapping logic will be added in a later
// phase once column names are confirmed.
//
// GolfClient / DemoSession / etc. remain the source of truth for all
// finalized data.  ImportRow is ephemeral staging storage only.

model ImportBatch {
  id                    Int       @id @default(autoincrement())
  originalFileName      String
  // Nullable in V1 — staff identity injection added in a future phase
  uploadedByStaffUserId Int?
  // Lifecycle: uploaded → parsed → reviewing → approved | failed
  status                String    @default("uploaded")
  rowCount              Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  uploadedBy    StaffUser?          @relation(fields: [uploadedByStaffUserId], references: [id])
  rows          ImportRow[]
  clubSummaries ImportClubSummary[]

  @@index([uploadedByStaffUserId])
  @@index([status])
}

model ImportRow {
  id               Int      @id @default(autoincrement())
  importBatchId    Int
  rowIndex         Int
  // Raw parsed row data — stored as-is from CSV/XLSX, no normalization
  rawData          Json
  // pending → reviewed | flagged
  status           String   @default("pending")
  // TODO: populate in validation phase when column mapping is known
  validationErrors Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  batch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId])
  @@index([status])
}

// Club-level aggregation of TrackMan shot rows.
// Generated from ImportRow.rawData grouped by Club.Type.
// Sales reps review and optionally edit these before final confirmation.
model ImportClubSummary {
  id               Int       @id @default(autoincrement())
  importBatchId    Int
  // Original club name parsed from Club.Type (null if blank in source data)
  originalClubName String?
  // Editable club name — defaults to originalClubName, or "Unassigned"
  clubName         String
  shotCount        Int
  avgClubSpeed     Decimal?  @db.Decimal(6, 2)
  avgBallSpeed     Decimal?  @db.Decimal(6, 2)
  avgSpinRate      Decimal?  @db.Decimal(8, 2)
  avgMaxHeight     Decimal?  @db.Decimal(6, 2)
  avgCarry         Decimal?  @db.Decimal(6, 2)
  avgTotal         Decimal?  @db.Decimal(6, 2)
  isManuallyEdited Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  batch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId])
}